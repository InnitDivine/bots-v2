# Copy to `.env` and fill your secrets.

TARGET_CHANNEL=your_channel
PREFERRED_BROADCASTER_NAME=your_name
BROADCASTER_ALIASES=your_name,your_channel
BOTS_FILE=bots.local.json

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# quickstart.py and add_bot_assistant.py add real bot usernames/tokens here.
TWITCH_BOT_USERNAME_EXAMPLE_CHILLBOT=example_chillbot
TWITCH_BOT_TOKEN_EXAMPLE_CHILLBOT=
TWITCH_BOT_USERNAME_EXAMPLE_HELPERBOT=example_helperbot
TWITCH_BOT_TOKEN_EXAMPLE_HELPERBOT=
TWITCH_BOT_USERNAME_EXAMPLE_HYPEBOT=example_hypebot
TWITCH_BOT_TOKEN_EXAMPLE_HYPEBOT=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=40

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westus
TRANSCRIPT_HTTP_ENDPOINT=http://127.0.0.1:5001/latest-transcript
TRANSCRIPT_HTTP_TO_S=2.0
MIC_MIN_WORDS=2
MIC_MIN_CHARS=6

SHARED_TRANSCRIPT_FILE=shared_transcript.json
CROSSBOT_RECENT_FILE=recent_messages.json
SHARED_META_FILE=shared_meta.json
HEARTBEAT_DIR=run/heartbeats
LOG_DIR=run/logs
DIVBOTS_MEMORY_FILE=run/divbot_memory.json
DIVBOTS_VIEWERS_FILE=run/divbot_viewers.json

HELIX_CACHE_FILE=run/helix_cache.json
HELIX_CACHE_TTL_S=300

MAX_MSG_PER_MINUTE=6
GLOBAL_MAX_MSG_PER_MINUTE=10
GLOBAL_MIN_COOLDOWN_SECS=2.0
BASE_MIN_COOLDOWN_SECS=12
DIVBOTS_REAL_CHAT_SUPPRESSION_SECONDS=20
DIVBOTS_MAX_CAST_MESSAGES_PER_5_MIN=18
DIVBOTS_IDLE_ONLY=false
DIVBOTS_ASCII_ONLY=true
DIVBOTS_ALLOW_BOT_TO_BOT=false
DIVBOTS_ORCHESTRATOR_TICK_SECS=2
DIVBOTS_ORCHESTRATOR_HINT_TTL_SECS=12
DIVBOTS_ORCHESTRATOR_IDLE_SILENCE_SECS=50
DIVBOTS_USE_JUDGE=false
DIVBOTS_JUDGE_MODEL=gpt-4o-mini

GAMEBANK_JSON=gamebank.json
GAMEBANK_TXT=gamebank.txt
