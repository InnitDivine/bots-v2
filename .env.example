# Copy to `.env` and fill your secrets.

TARGET_CHANNEL=innitdivine

TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

TWITCH_BOT_USERNAME_SIENNA=example_chillbot
TWITCH_BOT_TOKEN_SIENNA=

TWITCH_BOT_USERNAME_KNIGHT=example_modbot
TWITCH_BOT_TOKEN_KNIGHT=

TWITCH_BOT_USERNAME_SIMP=example_hypebot
TWITCH_BOT_TOKEN_SIMP=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=40

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westus
TRANSCRIPT_HTTP_ENDPOINT=http://127.0.0.1:5001/latest-transcript
TRANSCRIPT_HTTP_TO_S=2.0
MIC_MIN_WORDS=2
MIC_MIN_CHARS=6

SHARED_TRANSCRIPT_FILE=shared_transcript.json
CROSSBOT_RECENT_FILE=recent_messages.json
SHARED_META_FILE=shared_meta.json
HEARTBEAT_DIR=run/heartbeats
LOG_DIR=run/logs

HELIX_CACHE_FILE=run/helix_cache.json
HELIX_CACHE_TTL_S=300

MAX_MSG_PER_MINUTE=6
BASE_MIN_COOLDOWN_SECS=12

GAMEBANK_JSON=gamebank.json
GAMEBANK_TXT=gamebank.txt
